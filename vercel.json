{
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/proyectos",
      "dest": "/proyectos.html"
    },
    {
      "src": "/progreso",
      "dest": "/progreso.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}